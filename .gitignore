# Flutter / Dart project-specific ignores

# Dart tooling
.dart_tool/
.packages

# Flutter plugin files generated by tooling
.flutter-plugins
.flutter-plugins-dependencies

# Build outputs
/build/

# Coverage and generated docs
/coverage/
**/doc/api/

# Generated plugin registrant files (platform-specific)
**/generated_plugin_registrant.*

# Windows
windows/flutter/ephemeral/
windows/build/
*.suo
*.user
*.userosscache
*.sln.docstates
*.[Cc]ache
!*.[Cc]ache/

# End of project-specific ignores
